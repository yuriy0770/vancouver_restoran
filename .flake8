[flake8]
max-line-length = 88
extend-ignore = E203, W503
exclude =
    .git,
    __pycache__,
    migrations,
    .venv,
    venv,
    env,
    static,
    media,
    report,
    *.html,
    *.css,
    *.js

import-order-style = pep8

max-complexity = 10

per-file-ignores =
    __init__.py:F401
    tests/*:S101
    */migrations/*:E501

format = default
show-source = true
statistics = true